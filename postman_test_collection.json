{
  "info": {
    "name": "Fairmark Backend - Clean Test Flow",
    "_postman_id": "5f11713e-4a6e-4e0f-854d-8a9ee9f8f1b7",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://fairmark-backend-production.up.railway.app" },
    { "key": "password", "value": "Passw0rd!" },
    { "key": "studentEmail", "value": "" },
    { "key": "doctorEmail", "value": "" },
    { "key": "adminEmail", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "doctorToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "assignmentId", "value": "" },
    { "key": "submissionId", "value": "" }
  ],
  "item": [
    {
      "name": "00 - Init Dynamic Emails",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const ts = Date.now();",
              "pm.collectionVariables.set('studentEmail', `student.${ts}@fairmark.test`);",
              "pm.collectionVariables.set('doctorEmail', `doctor.${ts}@fairmark.test`);",
              "pm.collectionVariables.set('adminEmail', `admin.${ts}@fairmark.test`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health is up', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "01 - Register Student",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Student\",\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"student\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register student success', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "const json = pm.response.json();",
              "if (json && json.token) pm.collectionVariables.set('studentToken', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Register Doctor",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Doctor\",\n  \"email\": \"{{doctorEmail}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"doctor\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register doctor success', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "const json = pm.response.json();",
              "if (json && json.token) pm.collectionVariables.set('doctorToken', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Register Doctor 2",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Doctor 2\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"doctor\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register doctor2 success', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "const json = pm.response.json();",
              "if (json && json.token) pm.collectionVariables.set('adminToken', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Create Assignment (Doctor)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{doctorToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Quiz Smoke\",\n  \"description\": \"Smoke assignment\",\n  \"assignmentText\": \"Answer all questions\",\n  \"totalMark\": 20,\n  \"dueDate\": \"2026-12-01T12:00:00.000Z\"\n}"
        },
        "url": "{{baseUrl}}/assignments"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create assignment success', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "const json = pm.response.json();",
              "if (json && json._id) pm.collectionVariables.set('assignmentId', json._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - List Assignments",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
        ],
        "url": "{{baseUrl}}/assignments"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('List assignments success', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Create Submission (Student)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{studentToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "assignmentId", "value": "{{assignmentId}}", "type": "text" },
            { "key": "answerText", "value": "This is my answer", "type": "text" }
          ]
        },
        "url": "{{baseUrl}}/submissions"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create submission success', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "const json = pm.response.json();",
              "if (json && json._id) pm.collectionVariables.set('submissionId', json._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "07 - Grade Submission (Doctor)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{doctorToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"score\": 18\n}"
        },
        "url": "{{baseUrl}}/submissions/{{submissionId}}/grade"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Grade submission success', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "08 - AI Detection",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{studentToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"This is a sample answer for detector check\"\n}"
        },
        "url": "{{baseUrl}}/ai-detection"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('AI detection reachable', function () {",
              "  pm.expect([200, 502]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "09 - Upload Assignment Model Answer (Manual File)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": "" }
          ]
        },
        "url": "{{baseUrl}}/assignments/{{assignmentId}}/model-answer"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Upload model answer returns 200/400', function () {",
              "  pm.expect([200, 400]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
