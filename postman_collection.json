{
  "info": {
    "name": "Fairmark Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4002"
    },
    {
      "key": "studentEmail",
      "value": "ali.hassan@student.test.com"
    },
    {
      "key": "doctorEmail",
      "value": "hayfa.wahby@doctor.test.com"
    },
    {
      "key": "password",
      "value": "Passw0rd!"
    },
    {
      "key": "studentToken",
      "value": ""
    },
    {
      "key": "doctorToken",
      "value": ""
    },
    {
      "key": "jobToken",
      "value": ""
    },
    {
      "key": "assignmentId",
      "value": ""
    },
    {
      "key": "submissionId",
      "value": ""
    },
    {
      "key": "jobId",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "adminEmail",
      "value": "admin.one@admin.test.com"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth - Register (Student)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Student\",\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const ts = Date.now();",
              "pm.collectionVariables.set(\"studentEmail\", `student.${ts}@student.test.com`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set(\"studentToken\", json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Login (Student)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set(\"studentToken\", json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Login (Doctor)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{doctorEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set(\"doctorToken\", json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Assignments - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{doctorToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Quiz 1\",\n  \"description\": \"Test\",\n  \"totalMark\": 10,\n  \"dueDate\": \"2026-03-01T12:00:00.000Z\"\n}"
        },
        "url": "{{baseUrl}}/assignments"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set(\"assignmentId\", json._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Assignments - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{doctorToken}}"
          }
        ],
        "url": "{{baseUrl}}/assignments"
      }
    },
    {
      "name": "Assignments - Get",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{doctorToken}}"
          }
        ],
        "url": "{{baseUrl}}/assignments/{{assignmentId}}"
      }
    },
    {
      "name": "Submissions - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "assignmentId",
              "value": "{{assignmentId}}",
              "type": "text"
            },
            {
              "key": "answerText",
              "value": "My answer",
              "type": "text"
            }
          ]
        },
        "url": "{{baseUrl}}/submissions"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set(\"submissionId\", json._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Submissions - My",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": "{{baseUrl}}/submissions/my"
      }
    },
    {
      "name": "AI Detection",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"This is a test answer\"\n}"
        },
        "url": "{{baseUrl}}/ai-detection"
      }
    },
    {
      "name": "Auth - Login (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set(\"adminToken\", json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Assignments - My",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{doctorToken}}"
          }
        ],
        "url": "{{baseUrl}}/assignments/my"
      }
    },
    {
      "name": "Assignments - Update",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{doctorToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Quiz 1 (Updated)\",\n  \"description\": \"Updated description\",\n  \"totalMark\": 10,\n  \"dueDate\": \"2026-03-01T12:00:00.000Z\"\n}"
        },
        "url": "{{baseUrl}}/assignments/{{assignmentId}}"
      }
    },
    {
      "name": "Assignments - Delete",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{doctorToken}}"
          }
        ],
        "url": "{{baseUrl}}/assignments/{{assignmentId}}"
      }
    },
    {
      "name": "Assignments - Upload Model Answer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{doctorToken}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": "{{baseUrl}}/assignments/{{assignmentId}}/model-answer"
      }
    },
    {
      "name": "Assignments - Submissions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{doctorToken}}"
          }
        ],
        "url": "{{baseUrl}}/assignments/{{assignmentId}}/submissions"
      }
    },
    {
      "name": "Submissions - Get",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": "{{baseUrl}}/submissions/{{submissionId}}"
      }
    },
    {
      "name": "Submissions - Grade",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{doctorToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"score\": 8\n}"
        },
        "url": "{{baseUrl}}/submissions/{{submissionId}}/grade"
      }
    },
    {
      "name": "Results - My",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": "{{baseUrl}}/results/my"
      }
    },
    {
      "name": "Results - Assignment",
      "request": {
        "method": "GET",
