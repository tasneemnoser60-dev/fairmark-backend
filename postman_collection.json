                     "name":  "00 - Init Dynamic Emails",
                     "request":  {
                                     "method":  "GET",
                                     "url":  "{{baseUrl}}/health"
                                 },
                     "event":  [
                                   {
                                       "listen":  "prerequest",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "const ts = Date.now();",
                                                                   "pm.collectionVariables.set(\u0027studentEmail\u0027, `student.${ts}@example.com`);",
                                                                   "pm.collectionVariables.set(\u0027doctorEmail\u0027, `doctor.${ts}@example.com`);",
                                                                   "pm.collectionVariables.set(\u0027adminEmail\u0027, `admin.${ts}@example.com`);"
                                                               ]
                                                  }
                                   },
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027Health is up\u0027, function () {",
                                                                   "  pm.expect(pm.response.code).to.eql(200);",
                                                                   "});"
                                                               ]
                                                  }
                                   }
                               ]
                 },
                 {
                     "name":  "01 - Register Student",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"name\": \"Student\",\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"student\"\n}"
                                              },
                                     "url":  "{{baseUrl}}/api/auth/register"
                                 },
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027Register student success\u0027, function () {",
                                                                   "  pm.expect([200, 201]).to.include(pm.response.code);",
                                                                   "});",
                                                                   "const json = pm.response.json();",
                                                                   "if (json \u0026\u0026 json.token) pm.collectionVariables.set(\u0027studentToken\u0027, json.token);"
                                                               ]
                                                  }
                                   }
                               ]
